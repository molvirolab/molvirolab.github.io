---
import ProteinViewer from './ProteinViewer.astro';
---
<section class="mission-section">
  <div class="story-container">
    <div class="mission-grid">
      <div class="mission-text-column fade-up">
        <span class="section-title">OUR MISSION</span>
        <h2 class="mission-headline">The Molecular Quest</h2>
        
        <div class="mission-description">
          <p class="lead">
            At the heart of the MJ's Lab lies a deep curiosity about viruses. Led by <strong>Dr. Muzafar Jan</strong>, our team is dedicated to pushing the boundaries of scientific understanding, primarily focused on studying HIV-1.
          </p>
          <p>
            Our research focuses on the intersection of molecular biology and virological techniques to explore HIV's glycan structures, genetic variability, and host interactions.
          </p>
        </div>

        <div class="quote-wrapper">
          <blockquote class="mission-quote">
            "Where molecules meet meaning."
          </blockquote>
        </div>
      </div>

      <div class="mission-visual-column">
        <ProteinViewer 
          cifPath="/illustrations/1gc1.cif" 
          label="HIV-1 gp120: CD4 Complex" 
          height="650px"
        />
      </div>
    </div>
  </div>
</section>

<style>
  .mission-section {
    padding: 120px 0;
    background: #050505;
  }

  .mission-grid {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 120px;
    align-items: center;
  }

  .mission-headline {
    font-size: clamp(3rem, 6vw, 5rem);
    margin: 1.5rem 0 2rem;
    line-height: 1.1;
  }

  .mission-description {
    margin-bottom: 3rem;
  }

  .lead {
    font-size: 1.4rem;
    line-height: 1.6;
    color: white;
    margin-bottom: 1.5rem;
    font-family: var(--font-serif);
  }

  .mission-description p:not(.lead) {
    font-size: 1.25rem;
    line-height: 1.8;
    opacity: 0.85;
  }

  .mission-quote {
    font-family: var(--font-serif);
    font-size: clamp(2rem, 4vw, 3rem);
    line-height: 1.2;
    font-style: italic;
    color: var(--accent-blue);
    border-left: 3px solid var(--accent-blue);
    padding: 10px 0 10px 40px;
    margin: 3rem 0;
    text-align: left;
    opacity: 1;
    font-weight: 500;
  }

  .image-frame {
    position: relative;
    width: 100%;
    overflow: hidden;
    background: #111;
  }

  .sharp-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .frame-accent {
    position: absolute;
    top: 20px;
    right: 20px;
    bottom: 20px;
    left: 20px;
    border: 1px solid rgba(255,255,255,0.1);
    pointer-events: none;
  }

  @media (max-width: 1024px) {
    .mission-grid {
      grid-template-columns: 1fr;
      gap: 60px;
    }
    .mission-section { padding: 100px 0; }
    .image-frame { max-height: 500px; }
  }

  @media (max-width: 768px) {
    .mission-headline { font-size: 3rem; }
    .mission-quote { font-size: 1.8rem; padding-left: 20px; }
  }
</style>
