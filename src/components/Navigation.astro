---
// Premium Cinematic Navigation Component
---

<nav class="science-nav">
  <div class="nav-container">
    <a href="/" class="nav-brand">
      MJ'S <span class="accent">LAB</span>
    </a>

   <div class="nav-links">
          <a href="/" class="nav-item">Home</a>
          <a href="/about" class="nav-item">About</a>
          <a href="/research" class="nav-item">Research</a>
          <a href="/publications" class="nav-item">Publications</a>
          <a href="/team" class="nav-item">Team</a>
          <a href="/lab-life" class="nav-item">Lab Life</a>
          <a href="/theses" class="nav-item">Theses</a>
          <a href="mailto:muzafarjan@gmail.com" class="nav-btn">CONTACT</a>
        </div>
  </div>
</nav>

<style>
  .science-nav {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    /* High-end frosted glass paneling effect */
    background: rgba(3, 7, 18, 0.7);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
  }

  .nav-container {
    max-width: 1300px;
    margin: 0 auto;
    padding: 18px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-brand {
    font-size: 1.15rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    color: #fff;
    text-decoration: none;
    font-family: system-ui, sans-serif;
  }

  .nav-brand .accent {
    color: #22d3ee; /* Matching neon cyan highlight */
    text-shadow: 0 0 10px rgba(34, 211, 238, 0.3);
  }

  .nav-links {
    display: flex;
    align-items: center;
    gap: 32px;
  }

  .nav-item {
    font-size: 0.85rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #94a3b8;
    text-decoration: none;
    transition: color 0.25s ease, text-shadow 0.25s ease;
  }

  .nav-item:hover {
    color: #fff;
    text-shadow: 0 0 8px rgba(255, 255, 255, 0.5);
  }

  /* Compact Command Action Button */
  .nav-btn {
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    color: #030712;
    background: #fff;
    padding: 8px 18px;
    border-radius: 4px;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .nav-btn:hover {
    background: #22d3ee;
    box-shadow: 0 0 15px rgba(34, 211, 238, 0.4);
    transform: translateY(-1px);
  }

  /* Basic Mobile Constraint Check */
  @media (max-width: 768px) {
    .nav-links { gap: 16px; }
    .nav-item { display: none; } /* Kept simple for raw code updates; hidden items keep layout tight */
    .nav-item:nth-child(1), .nav-item:nth-child(5) { display: inline-block; } 
  }
</style>
