---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Lab Life | Molecular Virology Lab">
  <section class="py-12 max-w-4xl mx-auto px-4 text-white">
    <h1 class="text-4xl font-bold mb-4">Lab Life & Gallery</h1>
    <p class="text-zinc-400 mb-8">A look inside our daily operations, culture, and collaborative spirit at the Interdisciplinary Research Centre (IRC).</p>
    
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 bg-zinc-900 p-6 rounded-xl border border-zinc-800">
      <p class="text-zinc-500 italic">Gallery module initialized. Ready for your first photo uploads!</p>
    </div>
  </section>
</MainLayout>
