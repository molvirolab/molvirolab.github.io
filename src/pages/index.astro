---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
---

<MainLayout 
  title="Home | Molecular Virology Lab"
  description="Decoding Virus Pathogenesis — Investigating HIV-1 molecular biology and genetic evolution at SP College Srinagar."
>
  <Navigation />

  <div class="science-matrix-wrapper">
    
    <section class="hero-stage">
      <div class="hiv-capsid-overlay"></div>
      <div class="content-wrapper">
        <div class="science-badge">
          <span class="scanner-line"></span> CORE VIROLOGY INFRASTRUCTURE
        </div>
        <h1 class="hero-title">
          MOLECULAR <span class="text-gradient">VIROLOGY</span> LAB
        </h1>
        <p class="hero-subtitle">Decoding HIV-1 Pathogenesis</p>
        <p class="hero-desc">Investigating structural glycan shields, genetic variability trajectories, and host-cell entry complexes at S.P. College Srinagar.</p>
        <div class="hero-actions">
          <a href="#structural-matrix" class="btn-primary">INITIALIZE 3D ANALYSIS</a>
          <a href="mailto:muzafarjan@gmail.com" class="btn-secondary">CONTACT PROTOCOL</a>
        </div>
      </div>
    </section>

    <section id="structural-matrix" class="viewer-section max-width-wrapper">
      <div class="section-label">DATA ACCESS // REPLICATING MOLECULAR VECTORS</div>
      <h2 class="section-heading">HIV-1 gp120 / CD4 Complex Interactive Rendering</h2>
      
      <div class="glass-viewer-frame">
        <div 
          id="mol-canvas" 
          class="viewer_3Dmoljs canvas-container" 
          data-pdb="1GC1" 
          data-backgroundcolor="0x030712" 
          data-style="cartoon:color=spectrum"
        ></div>
        
        <div class="scientific-legend">
          <h4>MODEL IDENTIFIER: PDB 1GC1</h4>
          <div class="legend-item"><span class="legend-dot spectral"></span> Spectrum Scale: Chain Map</div>
          <div class="legend-item"><span class="legend-dot blue"></span> Target Core: gp120 Core</div>
          <div class="legend-item"><span class="legend-dot emerald"></span> Receptor Vector: CD4 Interface</div>
        </div>
        
        <div class="viewer-instruction">
          <span>🖱️ Left-Click + Drag to rotate structural bonds • Scroll to zoom fields</span>
        </div>
      </div>
    </section>

    <section class="matrix-section max-width-wrapper">
      <div class="matrix-grid">
        <div class="matrix-card">
          <span class="card-num">01</span>
          <h3>Glycan Topography</h3>
          <p>Mapping the shielding mechanisms of viral envelope components to expose target vulnerabilities.</p>
        </div>
        <div class="matrix-card">
          <span class="card-num">02</span>
          <h3>Genetic Evolution</h3>
          <p>Tracking point mutations and structural alignment changes across regional isolates.</p>
        </div>
        <div class="matrix-card">
          <span class="card-num">03</span>
          <h3>Vector Kinetics</h3>
          <p>Simulating structural docking interfaces between viral entry mechanisms and host cellular receptors.</p>
        </div>
      </div>
    </section>

    <section id="quest" class="mission-section max-width-wrapper">
      <div class="grid-2col">
        <div class="mission-text-block">
          <div class="section-label">LABORATORY OBJECTIVE</div>
          <h2 class="section-heading">The Molecular Quest</h2>
          <p>Led by <strong>Dr. Muzafar Jan</strong>, our team targets the intersection of wet-lab molecular biology and structural bioinformatics to explore HIV's glycan layouts, genetic variations, and cellular entry paths.</p>
        </div>
        <div class="quote-container">
          <div class="quote-card">
            <span class="quote-mark">“</span>
            <blockquote>Where molecules meet meaning.</blockquote>
          </div>
        </div>
      </div>
    </section>

    <footer class="cinematic-footer">
      <div class="max-width-wrapper footer-content">
        <p>© 2026 Molecular Virology Lab. Department of Biochemistry, Sri Pratap (SP) College Srinagar.</p>
        <p class="credits">Created by <a href="https://bhatmohsin.netlify.app" target="_blank">Bhat Mohsin</a></p>
      </div>
    </footer>

  </div>
</MainLayout>

<script is:inline src="https://3dmol.org/build/3Dmol-min.js"></script>

<style>
  :root {
    --bg-dark: #020617;
    --card-glass: rgba(15, 23, 42, 0.6);
    --border-glass: rgba(255, 255, 255, 0.08);
    --neon-blue: #38bdf8;
    --neon-emerald: #34d399;
    --text-muted: #9ca3af;
  }

  .science-matrix-wrapper {
    padding-top: 80px;
    background-color: var(--bg-dark);
    color: #f3f4f6;
    font-family: system-ui, sans-serif;
    min-height: 100vh;
    /* High-contrast scientific grid background layout pattern */
    background-image: 
      linear-gradient(rgba(255,255,255,0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);
    background-size: 40px 40px;
  }

  .max-width-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Hero Stage with an abstract molecular geometric network pattern overlay */
  .hero-stage {
    position: relative;
    padding: 120px 24px 100px;
    text-align: center;
    overflow: hidden;
  }

  .hiv-capsid-overlay {
    position: absolute;
    inset: 0;
    /* Creates a dark molecular atmospheric focus point */
    background: radial-gradient(circle at 50% 30%, rgba(14, 116, 144, 0.15) 0%, rgba(2, 6, 23, 0) 60%);
    pointer-events: none;
  }

  .science-badge {
    position: relative;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(14, 116, 144, 0.1);
    border: 1px solid rgba(56, 189, 248, 0.2);
    padding: 6px 16px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-mono: monospace;
    letter-spacing: 0.15em;
    color: var(--neon-blue);
  }

  .scanner-line {
    width: 6px;
    height: 6px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 8px #fff;
  }

  .hero-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.03em;
    line-height: 1.1;
    margin: 24px 0 16px;
  }

  .text-gradient {
    background: linear-gradient(to right, #67e8f9, var(--neon-blue));
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .hero-subtitle {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: #e5e7eb;
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: 20px;
  }

  .hero-desc {
    max-width: 650px;
    margin: 0 auto 40px;
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.6;
  }

  .hero-actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: var(--neon-blue);
    color: #020617;
    padding: 14px 28px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 4px 14px rgba(56, 189, 248, 0.3);
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    background: #7dd3fc;
  }

  .btn-secondary {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid var(--border-glass);
    color: white;
    padding: 14px 28px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  /* 3D Framework Viewport Frame */
  .viewer-section {
    padding: 60px 24px 80px;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: var(--neon-blue);
    margin-bottom: 8px;
    font-weight: 600;
  }

  .section-heading {
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: -0.01em;
    margin-bottom: 32px;
  }

  .glass-viewer-frame {
    position: relative;
    background: #030712;
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 12px;
    overflow: hidden;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }

  .canvas-container {
    width: 100%;
    height: 550px;
    position: relative;
  }

  /* Structural Scientific Data Legend Overlay */
  .scientific-legend {
    position: absolute;
    top: 24px;
    left: 24px;
    background: rgba(2, 6, 23, 0.85);
    border: 1px solid var(--border-glass);
    padding: 20px;
    border-radius: 6px;
    backdrop-filter: blur(8px);
    z-index: 10;
  }

  .scientific-legend h4 {
    font-size: 0.8rem;
    letter-spacing: 0.05em;
    margin: 0 0 12px 0;
    color: #fff;
  }

  .legend-item {
    display: flex;
    align-items: center;
    gap: 10px;
    font-size: 0.8rem;
    color: #9ca3af;
    margin-bottom: 8px;
  }

  .legend-dot {
    width: 8px;
    height: 8px;
    border-radius: 50%;
  }
  .legend-dot.spectral { background: linear-gradient(to right, red, orange, yellow, green, blue); }
  .legend-dot.blue { background: var(--neon-blue); }
  .legend-dot.emerald { background: var(--neon-emerald); }

  .viewer-instruction {
    position: absolute;
    bottom: 24px;
    right: 24px;
    background: rgba(2, 6, 23, 0.8);
    padding: 8px 16px;
    border-radius: 4px;
    font-size: 0.8rem;
    color: #6b7280;
    border: 1px solid var(--border-glass);
  }

  /* Metric Info Cards */
  .matrix-section {
    padding: 40px 24px 100px;
  }

  .matrix-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .matrix-card {
    background: var(--card-glass);
    border: 1px solid var(--border-glass);
    padding: 40px;
    border-radius: 8px;
    position: relative;
  }

  .card-num {
    font-size: 0.8rem;
    color: var(--neon-blue);
    font-mono: monospace;
    display: block;
    margin-bottom: 16px;
  }

  .matrix-card h3 {
    font-size: 1.25rem;
    font-weight: 700;
    color: #fff;
    margin-bottom: 12px;
  }

  .matrix-card p {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  /* Mission Segment Layout */
  .mission-section {
    padding: 80px 24px 120px;
    border-top: 1px solid var(--border-glass);
  }

  .grid-2col {
    display: grid;
    grid-template-columns: 1.2fr 1fr;
    gap: 80px;
    align-items: center;
  }

  .mission-text-block p {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--text-muted);
  }

  .quote-container {
    display: flex;
    justify-content: center;
  }

  .quote-card {
    position: relative;
    background: rgba(255,255,255,0.01);
    border: 1px solid var(--border-glass);
    padding: 40px;
    border-radius: 8px;
  }

  .quote-mark {
    position: absolute;
    top: -10px;
    left: 24px;
    font-size: 4rem;
    color: rgba(56,189,248,0.1);
  }

  .quote-card blockquote {
    font-size: 1.4rem;
    font-style: italic;
    color: #e5e7eb;
    margin: 0;
  }

  /* Footer Layout */
  .cinematic-footer {
    border-top: 1px solid var(--border-glass);
    padding: 40px 0;
    font-size: 0.9rem;
    color: #4b5563;
  }

  .footer-content {
    display: flex;
    justify-content: space-between;
    align-items: center;
    flex-wrap: wrap;
    gap: 16px;
  }

  .credits a {
    color: #9ca3af;
    text-decoration: none;
  }

  @media (max-width: 968px) {
    .matrix-grid { grid-template-columns: 1fr; }
    .grid-2col { grid-template-columns: 1fr; gap: 40px; }
    .footer-content { flex-direction: column; text-align: center; }
  }
</style>
