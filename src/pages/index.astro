---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
---

<MainLayout 
  title="Home | Molecular Virology Lab"
  description="Decoding Virus Pathogenesis — Interactive 3D Structural Analysis Ecosystem."
>
  <Navigation />

  <div class="viral-workspace">
    
    <header class="hero-stage">
      
      <div class="microscopy-slider">
        <div class="slide active" style="background-image: url('https://images.unsplash.com/photo-1576086213369-97a306d36557?q=80&w=1600&auto=format&fit=crop');"></div>
        <div class="slide" style="background-image: url('https://images.unsplash.com/photo-1532187863486-abf9d39d6618?q=80&w=1600&auto=format&fit=crop');"></div>
        <div class="slide" style="background-image: url('https://images.unsplash.com/photo-1614850523459-c2f4c699c52e?q=80&w=1600&auto=format&fit=crop');"></div>
        <div class="dark-lens-overlay"></div>
      </div>

      <div class="content-container">
        <div class="science-badge"><span class="scanner-dot"></span> LIVE VECTOR ANALYSIS CORE</div>
        <h1 class="main-title">MOLECULAR <span class="accent-glow">VIROLOGY</span> LAB</h1>
        <p class="subtitle">Structural Dynamics & Pathogenesis Terminal</p>
        <p class="desc">Investigating HIV-1 molecular biology trajectories and genetic evolution at SP College Srinagar.</p>
        <div class="actions">
          <a href="#structural-matrix" class="btn-primary">INITIALIZE 3D MAP</a>
          <a href="mailto:muzafarjan@gmail.com" class="btn-secondary">CONTACT PROTOCOL</a>
        </div>
      </div>
    </header>

    <section id="structural-matrix" class="viewer-section max-width">
      <div class="matrix-label">DATA STREAMING // 3D MACROMOLECULAR COMPLEX</div>
      <h2 class="matrix-heading">HIV-1 gp120:CD4 Complex Interactive Rendering</h2>
      
      <div class="glass-viewer-frame">
        <div 
          id="mol-canvas" 
          class="viewer_3Dmoljs canvas-container" 
          data-pdb="1GC1" 
          data-backgroundcolor="0x030712" 
          data-style="cartoon:color=spectrum"
        ></div>
        
        <div class="scientific-legend">
          <h4>PDB IDENTIFIER: 1GC1</h4>
          <div class="legend-item"><span class="dot spectrum-fade"></span> Spectral Gradient: Chain Map</div>
          <div class="legend-item"><span class="dot cyan"></span> Target Core: gp120 Complex</div>
          <div class="legend-item"><span class="dot emerald"></span> Receptor Vector: CD4 Interface</div>
        </div>
        
        <div class="viewer-instruction">
          <span>🖱️ Left-Click + Drag to rotate bonds • Scroll to zoom fields</span>
        </div>
      </div>
    </section>

    <section class="research-focus-section max-width">
      <div class="focus-grid">
        <div class="focus-card">
          <span class="card-count">01</span>
          <h3>Glycan Topography</h3>
          <p>Analyzing the shielding mechanisms of viral envelope components to expose target vulnerabilities.</p>
        </div>
        <div class="focus-card">
          <span class="card-count">02</span>
          <h3>Genetic Variability</h3>
          <p>Tracking point mutations and structural alignment changes across regional isolates.</p>
        </div>
        <div class="focus-card">
          <span class="card-count">03</span>
          <h3>Host Kinetics</h3>
          <p>Modeling structural interfaces between viral entry mechanisms and host cellular receptors.</p>
        </div>
      </div>
    </section>

    <section id="quest" class="mission-bar max-width">
      <div class="glass-panel">
        <div class="panel-text">
          <div class="line-tag">INVESTIGATION FRAMEWORK</div>
          <h3>The Molecular Quest</h3>
          <p>At the heart of the MJ's Lab lies a deep curiosity about viruses. Led by <strong>Dr. Muzafar Jan</strong>, our configuration targets the intersection of wet-lab molecular biology and advanced multi-dimensional computational informatics.</p>
        </div>
        <div class="panel-quote">
          <p class="quote">"Where molecules meet meaning."</p>
        </div>
      </div>
    </section>

    <footer class="scientific-footer max-width">
      <p>© 2026 Molecular Virology Lab. Department of Biochemistry, Sri Pratap (SP) College Srinagar.</p>
      <p>System Infrastructure: <a href="https://bhatmohsin.netlify.app" target="_blank">Bhat Mohsin</a></p>
    </footer>

  </div>
</MainLayout>

<script is:inline src="https://3dmol.org/build/3Dmol-min.js"></script>

<script is:inline>
  document.addEventListener('DOMContentLoaded', () => {
    const slides = document.querySelectorAll('.microscopy-slider .slide');
    let currentSlideIndex = 0;

    setInterval(() => {
      if(slides.length === 0) return;
      slides[currentSlideIndex].classList.remove('active');
      currentSlideIndex = (currentSlideIndex + 1) % slides.length;
      slides[currentSlideIndex].classList.add('active');
    }, 3000);
  });
</script>

<style>
  :root {
    --bg-dark: #030712;
    --card-glass: rgba(15, 23, 42, 0.4);
    --border-glass: rgba(255, 255, 255, 0.08);
    --neon-cyan: #22d3ee;
    --neon-emerald: #34d399;
    --gold-premium: #fef3c7;
    --text-muted: #94a3b8;
  }

  .viral-workspace {
    padding-top: 100px;
    background-color: var(--bg-dark);
    color: #e2e8f0;
    font-family: system-ui, sans-serif;
    min-height: 100vh;
    background-image: 
      linear-gradient(rgba(255,255,255,0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .max-width {
    max-width: 1300px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .hero-stage {
    position: relative;
    padding: 100px 24px 80px;
    text-align: center;
    overflow: hidden;
  }

  .microscopy-slider {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .microscopy-slider .slide {
    position: absolute;
    inset: 0;
    background-size: cover;
    background-position: center;
    opacity: 0;
    transition: opacity 1.2s ease-in-out;
  }

  .microscopy-slider .slide.active {
    opacity: 1;
  }

  .dark-lens-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to bottom,
      rgba(3, 7, 18, 0.65) 0%,
      rgba(3, 7, 18, 0.85) 60%,
      var(--bg-dark) 100%
    );
  }

  .content-container {
    position: relative;
    z-index: 10;
  }

  .science-badge {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: rgba(3, 105, 161, 0.2);
    border: 1px solid rgba(56, 189, 248, 0.3);
    color: var(--neon-cyan);
    padding: 6px 14px;
    border-radius: 4px;
    font-size: 0.75rem;
    font-family: monospace;
    letter-spacing: 0.1em;
  }

  .scanner-dot {
    width: 6px;
    height: 6px;
    background: #fff;
    border-radius: 50%;
    box-shadow: 0 0 10px #fff;
  }

  .main-title {
    font-size: clamp(2.5rem, 6vw, 4.5rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    line-height: 1.1;
    margin: 20px 0 16px;
    color: var(--gold-premium);
    text-shadow: 0 4px 20px rgba(0,0,0,0.6);
  }

  .accent-glow {
    background: linear-gradient(to right, #67e8f9, #a5b4fc);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
  }

  .subtitle {
    font-size: clamp(1.25rem, 2.5vw, 1.75rem);
    color: #e5e7eb;
    font-weight: 400;
    letter-spacing: 0.05em;
    margin-bottom: 12px;
    text-shadow: 0 2px 10px rgba(0,0,0,0.5);
  }

  .desc {
    max-width: 650px;
    margin: 0 auto 40px;
    color: #cbd5e1;
    font-size: 1.1rem;
    line-height: 1.6;
    text-shadow: 0 2px 8px rgba(0,0,0,0.5);
  }

  .actions {
    display: flex;
    gap: 16px;
    justify-content: center;
    flex-wrap: wrap;
  }

  .btn-primary {
    background: #fff;
    color: #030712;
    padding: 14px 28px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-primary:hover {
    transform: translateY(-2px);
    background: #e2e8f0;
  }

  .btn-secondary {
    background: rgba(3, 7, 18, 0.4);
    border: 1px solid rgba(255,255,255,0.2);
    backdrop-filter: blur(4px);
    color: white;
    padding: 14px 28px;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.05em;
    text-decoration: none;
    transition: all 0.2s ease;
  }

  .btn-secondary:hover {
    background: rgba(255, 255, 255, 0.05);
  }

  .viewer-section { padding: 60px 24px 80px; }
  .matrix-label { font-size: 0.75rem; letter-spacing: 0.2em; color: var(--neon-cyan); margin-bottom: 8px; font-weight: 600; }
  .matrix-heading { font-size: 2rem; font-weight: 800; letter-spacing: -0.01em; margin-bottom: 32px; }
  .glass-viewer-frame { position: relative; background: #030712; border: 1px solid rgba(255, 255, 255, 0.1); border-radius: 12px; overflow: hidden; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5); }
  .canvas-container { width: 100%; height: 550px; position: relative; }

  .scientific-legend { position: absolute; top: 24px; left: 24px; background: rgba(2, 6, 23, 0.8); border: 1px solid var(--border-glass); padding: 20px; border-radius: 6px; backdrop-filter: blur(8px); z-index: 10; }
  .scientific-legend h4 { font-size: 0.8rem; letter-spacing: 0.05em; margin: 0 0 12px 0; color: #fff; }
  .legend-item { display: flex; align-items: center; gap: 10px; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 8px; }
  .dot { width: 8px; height: 8px; border-radius: 50%; }
  .dot.spectrum-fade { background: linear-gradient(to right, red, orange, yellow, green, blue); }
  .dot.cyan { background: var(--neon-cyan); }
  .dot.emerald { background: var(--neon-emerald); }
  .viewer-instruction { position: absolute; bottom: 24px; right: 24px; background: rgba(2, 6, 23, 0.8); padding: 8px 16px; border-radius: 4px; font-size: 0.8rem; color: #6b7280; border: 1px solid var(--border-glass); }

  .research-focus-section { padding: 40px 24px 100px; }
  .focus-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }
  .focus-card { background: var(--card-glass); border: 1px solid var(--border-glass); padding: 40px; border-radius: 8px; position: relative; transition: transform 0.3s ease, border-color 0.3s ease; }
  .focus-card:hover { transform: translateY(-4px); border-color: rgba(255,255,255,0.12); }
  .card-count { font-size: 0.8rem; color: var(--neon-cyan); font-family: monospace; display: block; margin-bottom: 16px; }
  .focus-card h3 { font-size: 1.25rem; font-weight: 700; color: #fff; margin-bottom: 12px; }
  .focus-card p { font-size: 0.95rem; color: var(--text-muted); line-height: 1.6; margin: 0; }

  .mission-bar { padding: 40px 24px 100px; }
  .glass-panel { background: rgba(15, 23, 42, 0.3); border: 1px solid var(--border-glass); border-radius: 16px; padding: 40px; display: flex; justify-content: space-between; align-items: center; gap: 40px; backdrop-filter: blur(10px); }
  .line-tag { font-size: 0.75rem; letter-spacing: 0.2em; color: var(--neon-cyan); margin-bottom: 8px; font-weight: 600; }
  .panel-text h3 { font-size: 1.75rem; margin: 8px 0 12px; font-weight: 800; color: #fff; }
  .panel-text p { color: var(--text-muted); margin: 0; line-height: 1.7; max-width: 700px; }
  .panel-quote { border-left: 2px solid var(--neon-cyan); padding-left: 24px; min-width: 250px; }
  .quote { font-size: 1.3rem; font-style: italic; color: #fff; margin: 0; font-weight: 300; }

  .scientific-footer { border-top: 1px solid var(--border-glass); padding: 30px 24px; display: flex; justify-content: space-between; color: #475569; font-size: 0.85rem; }
  .scientific-footer a { color: #64748b; text-decoration: none; }

  @media (max-width: 968px) {
    .focus-grid { grid-template-columns: 1fr; gap: 16px; }
    .glass-panel { flex-direction: column; align-items: flex-start; gap: 24px; }
    .scientific-footer { flex-direction: column; text-align: center; gap: 10px; }
  }
</style>
