---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import { getCollection } from 'astro:content';

const newsItems = await getCollection('news');
const sortedNews = newsItems.sort((a, b) => (a.data.order || 100) - (b.data.order || 100));

const projects = await getCollection('projects');
const sortedProjects = projects.sort((a, b) => (a.data.order || 100) - (b.data.order || 100));
---

<MainLayout 
  title="About Us"
  description="Learn about the history, facilities, and ongoing news at Dr. Muzafar Jan's Molecular Virology Lab in Srinagar, Jammu & Kashmir."
>
  <Navigation />
  <div class="about-container">
    <header class="section-header fade-up">
      <span class="section-title">THE FOUNDATION</span>
      <h1>About the Lab</h1>
      <p class="subtitle">A closer look at our history, our facility, and our collective journey in molecular science.</p>
    </header>

    <section class="about-hero fade-up">
      <div class="carousel-container">
        <div class="about-carousel">
          <div class="about-slide" style="background-image: url('/images/about/group-1.jpg');">
             <div class="slide-caption">PI at Action</div>
          </div>
          <div class="about-slide" style="background-image: url('/images/about/group-2.jpg');">
             <div class="slide-caption">Lab Life Outdoors</div>
          </div>
          <div class="about-slide" style="background-image: url('/images/about/group-3.jpg');">
             <div class="slide-caption">Lab Work Session</div>
          </div>
        </div>
        <div class="carousel-controls">
          <button class="prev-btn">↖</button>
          <button class="next-btn">↗</button>
        </div>
      </div>
    </section>

    <section class="ongoing-research fade-up">
      <header class="section-header-small">
        <span class="section-title">THE ENDEAVOR</span>
        <h2>Ongoing Research Projects</h2>
      </header>
      <div class="projects-list">
        {sortedProjects.map((project, index) => (
          <div class="project-card">
            <span class="project-num">{String(index + 1).padStart(2, '0')}</span>
            <p>{project.data.title}</p>
          </div>
        ))}
      </div>
    </section>

    <div class="details-grid-full">
      <section class="details-text fade-up">
        <h2>Our Facility</h2>
        <p>
          Based at the <strong>Interdisciplinary Research Centre (IRC)</strong>, Sri Pratap College Srinagar, our laboratory is equipped with state-of-the-art molecular biology and virological infrastructure. The lab serves as a hub for scientific excellence in the region, fostering collaborative research and training the next generation of molecular biologists.
        </p>
        <p>
          We operate at the intersection of basic science and clinical relevance, bridging the gap between molecular interactions and human pathogenic outcomes. Our environment is one of rigorous inquiry and supportive mentorship.
        </p>
      </section>
    </div>

    <section class="news-section fade-up">
      <header class="section-header-small">
        <span class="section-title">LATEST UPDATES</span>
        <h2>Lab News</h2>
      </header>
      <div class="news-content">
        {sortedNews.map(async (news) => {
          const { Content } = await news.render();
          return (
            <div class={`news-card ${news.data.isHighlight ? 'highlight' : ''}`}>
              <div class="news-date">{news.data.date}</div>
              <h3>{news.data.title}</h3>
              <div class="news-body">
                <Content />
              </div>
            </div>
          );
        })}
      </div>
    </section>

    <section class="location-section fade-up">
      <div class="location-grid">
        <div class="location-info">
          <span class="section-title">FIND US</span>
          <h2>The IRC Laboratory</h2>
          <p class="location-address">
            Interdisciplinary Research Centre,<br/> 
            Sri Pratap College,<br/> 
            M.A. Road, Srinagar, J&K, 190001
          </p>
        </div>
        <div class="map-container">
          <iframe 
            src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3305.2018245532577!2d74.8150495764121!3d34.07204271646734!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x38e18f0868848135%3A0xe53d3000940fc798!2sSri%20Pratap%20College!5e0!3m2!1sen!2sin!4v1709322201234!5m2!1sen!2sin" 
            width="100%" 
            height="100%" 
            style="border:0; filter: grayscale(1) invert(1) opacity(0.8);" 
            allowfullscreen="" 
            loading="lazy" 
            referrerpolicy="no-referrer-when-downgrade"
            class="map-frame"
          ></iframe>
        </div>
      </div>
    </section>
  </div>
</MainLayout>

<script>
  let currentSlide = 0;
  const slides = document.querySelectorAll('.about-slide');
  const totalSlides = slides.length;

  function showSlide(index) {
    slides.forEach((slide, i) => {
      slide.style.opacity = i === index ? '1' : '0';
      slide.style.zIndex = i === index ? '1' : '0';
    });
  }

  document.querySelector('.next-btn')?.addEventListener('click', () => {
    currentSlide = (currentSlide + 1) % totalSlides;
    showSlide(currentSlide);
  });

  document.querySelector('.prev-btn')?.addEventListener('click', () => {
    currentSlide = (currentSlide - 1 + totalSlides) % totalSlides;
    showSlide(currentSlide);
  });

  showSlide(0);
</script>

<style>
  .about-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 40px 40px;
  }

  .section-header {
    margin-bottom: 40px;
    text-align: center;
  }

  h1 { font-size: clamp(3rem, 7vw, 5rem); line-height: 1.1; margin: 1rem 0; }
  .subtitle { 
    opacity: 0.8; 
    max-width: 650px; 
    margin: 0 auto; 
    line-height: 1.6; 
    font-size: 1.25rem; 
    letter-spacing: 0.05em;
  }

  /* Carousel */
  .about-hero {
    margin-bottom: 100px;
  }

  .carousel-container {
    position: relative;
    width: 100%;
    aspect-ratio: 21/9;
    background: #111;
    overflow: hidden;
  }

  .about-carousel {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .about-slide {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background-size: cover;
    background-position: center;
    transition: opacity 1s ease;
    opacity: 0;
  }

  .slide-caption {
    position: absolute;
    bottom: 30px;
    left: 30px;
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(8px);
    padding: 12px 24px;
    font-size: 0.9rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    font-weight: 500;
  }

  .carousel-controls {
    position: absolute;
    bottom: 30px;
    right: 30px;
    display: flex;
    gap: 15px;
    z-index: 10;
  }

  .carousel-controls button {
    background: white;
    color: black;
    border: none;
    width: 45px;
    height: 45px;
    cursor: pointer;
    font-size: 1.1rem;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .carousel-controls button:hover {
    background: var(--accent-blue);
    color: white;
  }

  /* Details Grid */
  .details-grid-full {
    margin: 60px 0;
  }

  .details-text h2 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    margin-bottom: 20px;
  }

  .details-text p {
    font-size: 1.25rem;
    line-height: 1.8;
    opacity: 0.85;
    margin-bottom: 1.5rem;
  }

  /* Location Section */
  .location-section {
    margin-top: 80px;
    padding: 60px 0;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .location-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 100px;
    align-items: center;
  }

  .location-info h2 {
    font-size: clamp(2.5rem, 4vw, 3.5rem);
    margin: 20px 0;
  }

  .location-address {
    font-size: 1.3rem;
    line-height: 1.6;
    opacity: 0.8;
    color: #ccc;
  }

  .map-container {
    width: 100%;
    aspect-ratio: 16/10;
  }

  .map-frame {
    width: 100%;
    height: 100%;
    background: #0a0a0a;
    border: 1px solid rgba(255,255,255,0.1);
  }

  .map-marker {
    font-size: 2.5rem;
    animation: bounce 2s infinite;
  }

  /* Ongoing Research Section */
  .ongoing-research {
    margin: 100px 0;
    padding-top: 80px;
    border-top: 1px solid rgba(255,255,255,0.05);
  }

  .section-header-small {
    margin-bottom: 60px;
  }

  .section-header-small h2 {
    font-size: clamp(2rem, 4vw, 3rem);
    margin-top: 1rem;
  }

  .projects-list {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 40px;
  }

  .project-card {
    background: rgba(255,255,255,0.02);
    padding: 40px;
    border: 1px solid rgba(255,255,255,0.05);
    transition: all 0.3s ease;
  }

  .project-card:hover {
    background: rgba(255,255,255,0.04);
    border-color: var(--accent-blue);
  }

  .project-num {
    display: block;
    font-family: var(--font-serif);
    color: var(--accent-blue);
    font-size: 1.6rem;
    margin-bottom: 20px;
    opacity: 0.9;
  }

  .project-card p {
    font-size: 1.1rem;
    line-height: 1.7;
    opacity: 0.9;
  }

  /* News Section Styles */
  .news-section {
    margin: 100px 0;
  }

  .news-content {
    max-width: 1000px;
  }

  .news-card {
    background: rgba(255, 255, 255, 0.03);
    border-left: 4px solid var(--accent-blue, #6366f1);
    padding: 50px;
    position: relative;
    overflow: hidden;
  }

  .news-card.highlight {
    background: linear-gradient(135deg, rgba(99, 102, 241, 0.08) 0%, rgba(0, 0, 0, 0) 100%);
  }

  .news-date {
    font-size: 0.85rem;
    letter-spacing: 0.2em;
    color: var(--accent-blue, #6366f1);
    margin-bottom: 20px;
    font-weight: 600;
  }

  .news-card h3 {
    font-size: 2.2rem;
    margin-bottom: 25px;
    text-transform: none;
    letter-spacing: 0;
    font-family: var(--font-serif);
  }

  .news-card p {
    font-size: 1.2rem;
    line-height: 1.8;
    opacity: 0.9;
    margin-bottom: 20px;
  }

  @keyframes bounce {
    0%, 100% { transform: translateY(0); }
    50% { transform: translateY(-10px); }
  }

  @media (max-width: 1024px) {
    .location-grid { grid-template-columns: 1fr; gap: 60px; }
  }

  @media (max-width: 768px) {
    .about-container { padding: 120px 24px 60px; }
    .carousel-container { aspect-ratio: 4/3; }
    .news-card { padding: 35px 25px; }
    .location-section { padding: 60px 0; }
  }

  .news-card p strong {
    color: white;
    font-weight: 600;
  }
</style>
