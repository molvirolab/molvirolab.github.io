---
import { getCollection } from 'astro:content';
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';

// 1. Fetch active interns from the 'team' folder (ignoring the boss if his file is there)
const teamFiles = await getCollection('team');
const activeInterns = teamFiles
  .filter(member => member.slug !== 'muzzafar-jan')
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// 2. Fetch past members from the brand new 'alumni' folder
const alumniFiles = await getCollection('alumni');
const alumniMembers = alumniFiles
  .sort((a, b) => (a.data.order || 0) - (b.data.order || 0));

// 3. Pre-render texts safely
const renderedActive = await Promise.all(
  activeInterns.map(async (member) => {
    const { Content } = await member.render();
    return { data: member.data, Content };
  })
);

const renderedAlumni = await Promise.all(
  alumniMembers.map(async (member) => {
    const { Content } = await member.render();
    return { data: member.data, Content };
  })
);
---

<MainLayout 
  title="Team | Molecular Virology Lab"
  description="Meet the investigators, molecular biologists, and research trainees driving discoveries at MJ's Lab."
>
  <Navigation />

  <div class="main-content-wrapper">
    <!-- Header Stage -->
    <header class="team-header max-width-wrapper">
      <div class="section-label">LABORATORY ROSTER</div>
      <h1>Investigative Roster</h1>
      <p class="subtitle">The minds parsing complex viral data matrices, structural phenotypes, and molecular topography.</p>
    </header>

    <!-- PERMANENT PRINCIPAL INVESTIGATOR SECTION -->
    <section class="pi-section max-width-wrapper">
      <div class="pi-card">
        <div class="pi-glow"></div>
        <div class="pi-meta">
          <span class="pi-tag">PRINCIPAL INVESTIGATOR</span>
          <h2>Dr. Muzafar Jan</h2>
          <p class="pi-title">Head of Molecular Virology Laboratory</p>
          <p class="pi-bio">Coordinating the intersection of clinical virology protocols and multi-dimensional computational structural informatics. Dr. Jan leads the lab's exploration into HIV-1 glycan topography, mutational resistance mapping, and novel host-cell binding profiles within the Department of Biochemistry.</p>
          <div class="pi-contact-row">
            <span>✉️ muzafarjan@gmail.com</span>
            <span>📍 S.P. College Srinagar</span>
          </div>
        </div>
      </div>
    </section>

    <!-- ACTIVE RESEARCH COHORT (Pulls from src/content/team/) -->
    <section class="members-section max-width-wrapper">
      <div class="section-label-mid">ACTIVE RESEARCH COHORT</div>
      <div class="members-grid">
        {renderedActive.map(({ data, Content }) => (
          <div class="member-card">
            <div class="member-badge">{data.role}</div>
            <h3>{data.name}</h3>
            <p class="member-role">{data.role}</p>
            <div class="member-desc"><Content /></div>
            {data.email && <div class="member-email">✉️ {data.email}</div>}
          </div>
        ))}
      </div>
    </section>

    <!-- ALUMNI SECTION (Pulls from src/content/alumni/) -->
    {renderedAlumni.length > 0 && (
      <section class="alumni-section max-width-wrapper">
        <div class="section-label-alumni">LABORATORY ALUMNI</div>
        <p class="alumni-subtitle">Honoring the past researchers and scholars who have contributed to our scientific milestones.</p>
        <div class="alumni-grid">
          {renderedAlumni.map(({ data, Content }) => (
            <div class="alumni-card">
              <h3>{data.name}</h3>
              <p class="alumni-role">{data.role}</p>
              <div class="alumni-desc"><Content /></div>
            </div>
          ))}
        </div>
      </section>
    )}
  </div>
</MainLayout>

<style>
  :root {
    --bg-dark: #030712;
    --card-glass: rgba(15, 23, 42, 0.4);
    --border-glass: rgba(255, 255, 255, 0.06);
    --neon-blue: #38bdf8;
    --text-muted: #9ca3af;
  }

  .main-content-wrapper {
    padding-top: 100px;
    background-color: var(--bg-dark);
    color: #f3f4f6;
    font-family: system-ui, sans-serif;
    min-height: 100vh;
    background-image: 
      linear-gradient(rgba(255,255,255,0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .max-width-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  .team-header {
    text-align: center;
    padding: 60px 24px 40px;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--neon-blue);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 12px;
  }

  h1 { font-size: clamp(2.5rem, 5vw, 4rem); font-weight: 900; letter-spacing: -0.02em; margin-bottom: 16px; color: #fff; }
  .subtitle { font-size: clamp(1.1rem, 2vw, 1.3rem); color: var(--text-muted); max-width: 700px; margin: 0 auto; line-height: 1.6; font-weight: 300; }
  .pi-section { padding-bottom: 40px; }

  .pi-card {
    position: relative;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.6) 0%, rgba(3, 7, 18, 0.8) 100%);
    border: 1px solid rgba(56, 189, 248, 0.15);
    border-radius: 16px;
    padding: 48px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .pi-glow {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.1) 0%, rgba(0,0,0,0) 70%);
    pointer-events: none;
  }

  .pi-tag { font-size: 0.7rem; font-weight: 700; letter-spacing: 0.15em; color: var(--neon-blue); display: block; margin-bottom: 12px; }
  .pi-meta h2 { font-size: 2.25rem; font-weight: 800; color: #fff; margin: 0 0 6px 0; letter-spacing: -0.01em; }
  .pi-title { font-size: 1.1rem; color: #e5e7eb; margin: 0 0 24px 0; font-weight: 500; }
  .pi-bio { color: var(--text-muted); font-size: 1.1rem; line-height: 1.7; max-width: 900px; margin-bottom: 32px; }
  .pi-contact-row { display: flex; gap: 32px; font-size: 0.9rem; color: #64748b; font-family: monospace; }

  .members-section { padding: 40px 24px 80px; border-top: 1px solid var(--border-glass); }
  .section-label-mid { font-size: 0.75rem; letter-spacing: 0.15em; color: #64748b; margin-bottom: 32px; font-weight: 600; }
  .members-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 24px; }

  .member-card {
    background: var(--card-glass);
    border: 1px solid var(--border-glass);
    padding: 32px;
    border-radius: 12px;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .member-card:hover { transform: translateY(-4px); border-color: rgba(56, 189, 248, 0.25); }

  .member-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--neon-blue);
    background: rgba(56, 189, 248, 0.06);
    padding: 4px 8px;
    border-radius: 4px;
    align-self: flex-start;
    margin-bottom: 20px;
    text-transform: uppercase;
  }

  .member-card h3 { font-size: 1.25rem; font-weight: 700; color: #fff; margin: 0 0 4px 0; }
  .member-role { font-size: 0.85rem; color: #e5e7eb; margin: 0 0 16px 0; font-weight: 500; }
  .member-desc { font-size: 0.9rem; color: var(--text-muted); line-height: 1.6; margin-bottom: 20px; }
  .member-email { margin-top: auto; font-size: 0.75rem; font-family: monospace; color: #4b5563; }

  /* ALUMNI STYLES */
  .alumni-section { padding: 60px 24px 120px; border-top: 1px solid rgba(255, 255, 255, 0.04); }
  .section-label-alumni { font-size: 0.75rem; letter-spacing: 0.2em; color: #64748b; text-transform: uppercase; font-weight: 600; margin-bottom: 8px; }
  .alumni-subtitle { font-size: 1rem; color: #64748b; margin-bottom: 40px; }
  .alumni-grid { display: grid; grid-template-columns: repeat(4, 1fr); gap: 20px; }
  .alumni-card { background: rgba(15, 23, 42, 0.2); border: 1px solid rgba(255, 255, 255, 0.03); padding: 24px; border-radius: 8px; }
  .alumni-card h3 { font-size: 1.1rem; font-weight: 600; color: #cbd5e1; margin: 0 0 4px 0; }
  .alumni-role { font-size: 0.8rem; color: #64748b; margin: 0 0 12px 0; }
  .alumni-desc { font-size: 0.85rem; color: var(--text-muted); line-height: 1.5; }

  @media (max-width: 1024px) {
    .members-grid { grid-template-columns: repeat(2, 1fr); }
    .alumni-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .members-grid { grid-template-columns: 1fr; }
    .alumni-grid { grid-template-columns: 1fr; }
  }
</style>
