---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
---

<MainLayout 
  title="Team | Molecular Virology Lab"
  description="Meet the investigators, molecular biologists, and research trainees driving discoveries at MJ's Lab."
>
  <Navigation />

  <div class="main-content-wrapper">
    <header class="team-header max-width-wrapper">
      <div class="section-label">LABORATORY ROSTER</div>
      <h1>Investigative Roster</h1>
      <p class="subtitle">The minds parsing complex viral data matrices, structural phenotypes, and molecular topography.</p>
    </header>

    <section class="pi-section max-width-wrapper">
      <div class="pi-card">
        <div class="pi-glow"></div>
        <div class="pi-meta">
          <span class="pi-tag">PRINCIPAL INVESTIGATOR</span>
          <h2>Dr. Muzafar Jan</h2>
          <p class="pi-title">Head of Molecular Virology Laboratory</p>
          <p class="pi-bio">Coordinating the intersection of clinical virology protocols and multi-dimensional computational structural informatics. Dr. Jan leads the lab's exploration into HIV-1 glycan topography, mutational resistance mapping, and novel host-cell binding profiles within the Department of Biochemistry.</p>
          <div class="pi-contact-row">
            <span>✉️ muzafarjan@gmail.com</span>
            <span>📍 S.P. College Srinagar</span>
          </div>
        </div>
      </div>
    </section>

    <section class="members-section max-width-wrapper">
      <div class="section-label-mid">RESEARCH COHORT</div>
      
      <div class="members-grid">
        
        <div class="member-card">
          <div class="member-badge">BIOPHYSICS</div>
          <h3>Uzair Ibrahim Bhat</h3>
          <p class="member-role">Research Associate</p>
          <p class="member-desc">Specializes in running interactive 3D vector matrices and parsing computational protein-ligand docking models.</p>
        </div>

        <div class="member-card panel-emerald">
          <div class="member-badge badge-emerald">GENOMICS</div>
          <h3>Danish Nazir</h3>
          <p class="member-role">Research Assistant</p>
          <p class="member-desc">Focuses on analyzing viral sequence datasets, phylogenetic mapping, and structural point mutation analysis.</p>
        </div>

        <div class="member-card panel-purple">
          <div class="member-badge badge-purple">TRAINEE</div>
          <h3>Lab Cohort Placeholder</h3>
          <p class="member-role">Biochemistry Scholar</p>
          <p class="member-desc">Assisting with traditional wet-lab target amplification arrays, PCR setups, and cell culture logs.</p>
        </div>

      </div>
    </section>
  </div>
</MainLayout>

<style>
  :root {
    --bg-dark: #030712;
    --card-glass: rgba(15, 23, 42, 0.4);
    --border-glass: rgba(255, 255, 255, 0.06);
    --neon-blue: #38bdf8;
    --neon-emerald: #34d399;
    --neon-purple: #a855f7;
    --text-muted: #9ca3af;
  }

  .main-content-wrapper {
    padding-top: 100px;
    background-color: var(--bg-dark);
    color: #f3f4f6;
    font-family: system-ui, sans-serif;
    min-height: 100vh;
    background-image: 
      linear-gradient(rgba(255,255,255,0.01) 1px, transparent 1px),
      linear-gradient(90deg, rgba(255,255,255,0.01) 1px, transparent 1px);
    background-size: 50px 50px;
  }

  .max-width-wrapper {
    max-width: 1200px;
    margin: 0 auto;
    padding: 0 24px;
  }

  /* Header Section */
  .team-header {
    text-align: center;
    padding: 60px 24px 40px;
  }

  .section-label {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: var(--neon-blue);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 12px;
  }

  h1 {
    font-size: clamp(2.5rem, 5vw, 4rem);
    font-weight: 900;
    letter-spacing: -0.02em;
    margin-bottom: 16px;
    color: #fff;
  }

  .subtitle {
    font-size: clamp(1.1rem, 2vw, 1.3rem);
    color: var(--text-muted);
    max-width: 700px;
    margin: 0 auto;
    line-height: 1.6;
    font-weight: 300;
  }

  /* Principal Investigator Hero Card */
  .pi-section {
    padding-bottom: 60px;
  }

  .pi-card {
    position: relative;
    background: linear-gradient(135deg, rgba(15, 23, 42, 0.6) 0%, rgba(3, 7, 18, 0.8) 100%);
    border: 1px solid rgba(56, 189, 248, 0.15);
    border-radius: 16px;
    padding: 48px;
    overflow: hidden;
    box-shadow: 0 20px 40px rgba(0,0,0,0.4);
  }

  .pi-glow {
    position: absolute;
    top: -20%;
    left: -10%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(56, 189, 248, 0.1) 0%, rgba(0,0,0,0) 70%);
    pointer-events: none;
  }

  .pi-tag {
    font-size: 0.7rem;
    font-weight: 700;
    letter-spacing: 0.15em;
    color: var(--neon-blue);
    display: block;
    margin-bottom: 12px;
  }

  .pi-meta h2 {
    font-size: 2.25rem;
    font-weight: 800;
    color: #fff;
    margin: 0 0 6px 0;
    letter-spacing: -0.01em;
  }

  .pi-title {
    font-size: 1.1rem;
    color: #e5e7eb;
    margin: 0 0 24px 0;
    font-weight: 500;
  }

  .pi-bio {
    color: var(--text-muted);
    font-size: 1.1rem;
    line-height: 1.7;
    max-width: 900px;
    margin-bottom: 32px;
  }

  .pi-contact-row {
    display: flex;
    gap: 32px;
    font-size: 0.9rem;
    color: #64748b;
    font-family: monospace;
  }

  /* Cohort Grid Layout */
  .members-section {
    padding: 40px 24px 120px;
    border-top: 1px solid var(--border-glass);
  }

  .section-label-mid {
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    color: #64748b;
    margin-bottom: 32px;
    font-weight: 600;
  }

  .members-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .member-card {
    background: var(--card-glass);
    border: 1px solid var(--border-glass);
    padding: 32px;
    border-radius: 12px;
    backdrop-filter: blur(8px);
    display: flex;
    flex-direction: column;
    transition: transform 0.3s ease, border-color 0.3s ease;
  }

  .member-card:hover {
    transform: translateY(-4px);
    border-color: rgba(56, 189, 248, 0.2);
  }
  .member-card.panel-emerald:hover { border-color: rgba(52, 211, 153, 0.2); }
  .member-card.panel-purple:hover { border-color: rgba(168, 85, 247, 0.2); }

  .member-badge {
    font-size: 0.65rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--neon-blue);
    background: rgba(56, 189, 248, 0.06);
    padding: 4px 8px;
    border-radius: 4px;
    align-self: flex-start;
    margin-bottom: 20px;
  }
  .member-badge.badge-emerald { color: var(--neon-emerald); background: rgba(52, 211, 153, 0.06); }
  .member-badge.badge-purple { color: var(--neon-purple); background: rgba(168, 85, 247, 0.06); }

  .member-card h3 {
    font-size: 1.3rem;
    font-weight: 700;
    color: #fff;
    margin: 0 0 4px 0;
  }

  .member-role {
    font-size: 0.9rem;
    color: #e5e7eb;
    margin: 0 0 16px 0;
  }

  .member-desc {
    font-size: 0.95rem;
    color: var(--text-muted);
    line-height: 1.6;
    margin: 0;
  }

  @media (max-width: 968px) {
    .members-grid { grid-template-columns: 1fr; }
    .pi-card { padding: 32px; }
    .pi-contact-row { flex-direction: column; gap: 8px; }
  }
</style>
