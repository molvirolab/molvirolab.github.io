---
import MainLayout from '../layouts/MainLayout.astro';
---
<MainLayout title="Theses | Molecular Virology Lab">
  <section class="py-12 max-w-4xl mx-auto px-4 text-white">
    <h1 class="text-4xl font-bold mb-4">Completed Theses & Dissertations</h1>
    <p class="text-zinc-400 mb-8">Explore the academic dissertations and major research achievements completed by scholars during their tenure at SP College Srinagar.</p>
    
    <ul class="space-y-4">
      <li class="p-6 bg-zinc-900 rounded-xl border border-zinc-800 text-zinc-400">
        <em>No thesis logs uploaded yet. Space allocated for incoming submissions.</em>
      </li>
    </ul>
  </section>
</MainLayout>
