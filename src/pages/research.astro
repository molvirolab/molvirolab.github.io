---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('research');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);
---

<MainLayout 
  title="Research | Molecular Virology Lab"
  description="Research streams and scientific investigations from the Molecular Virology Lab."
>
  <Navigation />
  
  <div class="research-container">
    <header class="section-header fade-up">
      <span class="section-title">THE ENDEAVOR</span>
      <h1>Our Research</h1>
      <p class="subtitle">Pushing the boundaries of molecular virology through rigorous inquiry and investigative science at SP College Srinagar.</p>
    </header>

    <section class="themes-section">
      <!-- Activates the custom grid layout built into your styles -->
      <div class="emes-grid">
        {sortedProjects.map((project, index) => (
          <div 
            class="theme-card research-trigger fade-up" 
            style={`animation-delay: ${index * 0.05}s; --theme-color: ${project.data.color || '#6366f1'}`}
            data-title={project.data.title}
            data-description={project.data.description}
            data-color={project.data.color || '#6366f1'}
          >
            <div class="card-accent"></div>
            <span class="theme-number">0{index + 1}</span>
            <h3>{project.data.title}</h3>
            <p>{project.data.description}</p>
            <div class="theme-footer">
              <span class="more-link">EXPLORE THEME <span>→</span></span>
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>

  <!-- Modal markup required by your script below -->
  <div id="research-modal" class="research-modal-container">
    <div class="modal-content">
      <button class="close-modal">×</button>
      <h2 id="modal-title"></h2>
      <div id="modal-description" class="modal-body-text"></div>
    </div>
  </div>
</MainLayout>

<script>
  const modal = document.getElementById('research-modal');
  const closeBtn = modal?.querySelector('.close-modal');
  const triggers = document.querySelectorAll('.research-trigger');

  triggers.forEach(btn => {
    btn.addEventListener('click', () => {
      const { title, description } = (btn as HTMLElement).dataset;
      
      const modalTitle = document.getElementById('modal-title');
      const modalDesc = document.getElementById('modal-description');
      
      if (modalTitle) modalTitle.textContent = title || '';
      if (modalDesc) modalDesc.innerHTML = description || '';
      
      modal?.classList.add('active');
      document.body.style.overflow = 'hidden';
    });
  });

  closeBtn?.addEventListener('click', () => {
    modal?.classList.remove('active');
    document.body.style.overflow = '';
  });

  window.addEventListener('click', (e) => {
    if (e.target === modal) {
      modal?.classList.remove('active');
      document.body.style.overflow = '';
    }
  });
</script>

<style>
  /* Your original lab styles completely preserved */
  .research-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 40px 40px;
  }
  .section-header {
    margin-bottom: 40px;
    max-width: 800px;
  }
  .section-title {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    color: #6366f1;
    text-transform: uppercase;
  }
  .section-header h1 {
    font-size: clamp(3.5rem, 8vw, 6rem);
    line-height: 1;
    font-weight: 700;
    margin: 1.5rem 0;
    color: #fff;
  }
  .subtitle {
    font-size: 1.25rem;
    line-height: 1.6;
    color: #a1a1aa;
  }
  
  /* Themes Grid Layout */
  .emes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 40px;
    margin-bottom: 60px;
  }
  .theme-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 60px 40px;
    position: relative;
    overflow: hidden;
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    display: flex;
    flex-direction: column;
    cursor: pointer;
  }
  .card-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--theme-color, #6366f1);
    opacity: 0.3;
    transition: all 0.6s ease;
  }
  .theme-card:hover {
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-10px);
    border-color: rgba(255, 255, 255, 0.1);
  }
  .theme-card:hover .card-accent {
    opacity: 1;
    width: 6px;
  }
  .theme-number {
    font-size: 1.1rem;
    color: var(--theme-color, #6366f1);
    margin-bottom: 40px;
    display: block;
    letter-spacing: 0.2em;
  }
  .theme-card h3 {
    font-size: 1.8rem;
    color: #fff;
    margin-bottom: 20px;
    line-height: 1.2;
  }
  .theme-card p {
    font-size: 1rem;
    line-height: 1.7;
    color: #a1a1aa;
    margin-bottom: 40px;
    flex-grow: 1;
  }
  .theme-footer {
    border-top: 1px solid rgba(255, 255, 255, 0.1);
    padding-top: 20px;
  }
  .more-link {
    font-size: 0.85rem;
    color: #fff;
    letter-spacing: 0.1em;
    display: inline-flex;
    align-items: center;
    gap: 5px;
  }

  /* Modal Styles */
  .research-modal-container {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: rgba(0, 0, 0, 0.85);
    z-index: 1000;
    justify-content: center;
    align-items: center;
    backdrop-filter: blur(4px);
  }
  .research-modal-container.active {
    display: flex;
  }
  .modal-content {
    background: #121214;
    border: 1px solid rgba(255, 255, 255, 0.1);
    padding: 50px 40px;
    max-width: 650px;
    width: 90%;
    border-radius: 20px;
    position: relative;
    color: #fff;
  }
  .close-modal {
    position: absolute;
    top: 24px;
    right: 24px;
    background: none;
    border: none;
    color: #a1a1aa;
    font-size: 2rem;
    cursor: pointer;
    transition: color 0.2s ease;
  }
  .close-modal:hover {
    color: #fff;
  }
  #modal-title {
    font-size: 2rem;
    font-weight: 700;
    margin-bottom: 20px;
    padding-right: 20px;
  }
  .modal-body-text {
    font-size: 1.1rem;
    line-height: 1.7;
    color: #d4d4d8;
  }
</style>
