---
import MainLayout from '../layouts/MainLayout.astro';
import Navigation from '../components/Navigation.astro';
import { getCollection } from 'astro:content';

const projects = await getCollection('research');
const sortedProjects = projects.sort((a, b) => a.data.order - b.data.order);

const publications = await getCollection('publications');
const sortedPublications = publications.sort((a, b) => b.data.year - a.data.year);
---

<MainLayout 
  title="Publications & Research"
  description="Research publications and scientific discoveries from the Molecular Virology Lab (MJ's Lab) specializing in HIV-1 molecular biology and genetic evolution."
>
  <Navigation />
  <div class="research-container">
    <header class="section-header fade-up">
      <span class="section-title">THE ENDEAVOR</span>
      <h1>Publications & <br/> Research</h1>
      <p class="subtitle">Pushing the boundaries of molecular virology through rigorous inquiry and investigative science at SP College Srinagar.</p>
    </header>

    <section class="publications-section fade-up">
      <header class="pub-header">
        <span class="section-title">CHRONOLOGY</span>
        <h2>Selected Publications</h2>
      </header>
      
      <div class="pub-list">
        {sortedPublications.map((pub, index) => (
          <div class="pub-item fade-up" style={`animation-delay: ${index * 0.05}s`}>
            <div class="pub-year">{pub.data.year}</div>
            <div class="pub-body">
              <h3>{pub.data.title}</h3>
              <div class="pub-meta">
                <span class="authors">{pub.data.authors}</span>
                <span class="journal">{pub.data.journal}</span>
              </div>
              {pub.data.link && (
                <a href={pub.data.link} target="_blank" class="pub-link">
                  VIEW PUBLICATION <span>↗</span>
                </a>
              )}
            </div>
          </div>
        ))}
      </div>
    </section>
  </div>
</MainLayout>

<script>
  const modal = document.getElementById('research-modal');
  const closeBtn = modal?.querySelector('.close-modal');
  const triggers = document.querySelectorAll('.research-trigger');

  triggers.forEach(btn => {
    btn.addEventListener('click', () => {
      const { title, description, color } = btn.dataset;
      
      const modalTitle = document.getElementById('modal-title');
      const modalDesc = document.getElementById('modal-description');
      
      if (modalTitle) {
        modalTitle.textContent = title || '';
        modalTitle.style.color = color || '';
      }
      if (modalDesc) {
        // Simple markdown-to-html (paragraph splitting)
        modalDesc.innerHTML = (description || '').split('\n\n').map(p => `<p>${p}</p>`).join('');
      }
      
      modal?.classList.add('active');
      document.body.style.overflow = 'hidden';
    });
  });

  const closeModal = () => {
    modal?.classList.remove('active');
    document.body.style.overflow = '';
  };

  closeBtn?.addEventListener('click', closeModal);
  modal?.addEventListener('click', (e) => {
    if (e.target === modal) closeModal();
  });
</script>

<style>
  .research-container {
    max-width: 1400px;
    margin: 0 auto;
    padding: 100px 40px 40px;
  }

  .section-header {
    margin-bottom: 40px;
    max-width: 800px;
  }

  h1 { font-size: clamp(3.5rem, 8vw, 6rem); line-height: 1; margin: 1.5rem 0; }
  .subtitle { 
    font-size: 1.25rem; 
    opacity: 0.8; 
    line-height: 1.6; 
    letter-spacing: 0.05em;
  }

  /* Themes Grid */
  .themes-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(350px, 1fr));
    gap: 40px;
    margin-bottom: 60px;
  }

  .theme-card {
    background: rgba(255, 255, 255, 0.02);
    border: 1px solid rgba(255, 255, 255, 0.05);
    padding: 60px 40px;
    position: relative;
    overflow: hidden;
    transition: all 0.6s cubic-bezier(0.23, 1, 0.32, 1);
    display: flex;
    flex-direction: column;
  }

  .card-accent {
    position: absolute;
    top: 0;
    left: 0;
    width: 4px;
    height: 100%;
    background: var(--theme-color);
    opacity: 0.3;
    transition: all 0.6s ease;
  }

  .theme-card:hover {
    background: rgba(255, 255, 255, 0.04);
    transform: translateY(-10px);
    border-color: rgba(255, 255, 255, 0.1);
  }

  .theme-card:hover .card-accent {
    width: 100%;
    opacity: 0.05;
  }

  .theme-number {
    font-family: var(--font-serif);
    font-size: 1.1rem;
    color: var(--theme-color);
    margin-bottom: 40px;
    display: block;
    letter-spacing: 0.2em;
  }

  .theme-card h3 {
    font-size: 1.8rem;
    margin-bottom: 20px;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.2;
  }

  .theme-card p {
    font-size: 1rem;
    line-height: 1.7;
    opacity: 0.6;
    margin-bottom: 40px;
    flex-grow: 1;
  }

  .theme-footer {
    border-top: 1px solid rgba(255,255,255,0.1);
    padding-top: 25px;
  }

  .learn-more-btn {
    background: transparent;
    border: none;
    color: white;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    padding: 0;
    cursor: pointer;
    font-weight: 600;
    transition: letter-spacing 0.3s ease;
    text-transform: uppercase;
  }

  .learn-more-btn:hover {
    letter-spacing: 0.4em;
    color: var(--theme-color);
  }

  /* Publications */
  .pub-header { margin-bottom: 80px; text-align: center; }
  .pub-list { max-width: 1000px; margin: 0 auto; }

  .pub-item {
    display: grid;
    grid-template-columns: 100px 1fr;
    gap: 40px;
    padding: 40px 0;
    border-bottom: 1px solid rgba(255, 255, 255, 0.1);
  }

  .pub-year {
    font-family: var(--font-serif);
    font-size: 1.6rem;
    opacity: 0.4;
  }

  .pub-body h3 {
    font-size: 1.5rem;
    margin-bottom: 15px;
    text-transform: none;
    letter-spacing: 0;
    line-height: 1.4;
  }

  .pub-meta {
    font-size: 1.1rem;
    opacity: 0.8;
    margin-bottom: 20px;
    display: flex;
    flex-direction: column;
    gap: 5px;
  }

  .authors { font-family: var(--font-serif); font-style: italic; }

  .pub-link {
    font-size: 0.75rem;
    letter-spacing: 0.2em;
    font-weight: 600;
    display: inline-flex;
    align-items: center;
    gap: 10px;
  }

  .pub-link span { transition: transform 0.3s ease; }
  .pub-link:hover span { transform: translate(3px, -3px); }

  @media (max-width: 768px) {
    .research-container { padding: 120px 24px 60px; }
    .pub-item { grid-template-columns: 1fr; gap: 10px; }
  }
</style>
